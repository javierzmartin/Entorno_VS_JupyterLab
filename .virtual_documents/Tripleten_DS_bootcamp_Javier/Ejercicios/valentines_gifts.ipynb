import pandas as pd 
df = pd.read_csv('C:/Users/becem/Desktop/Entorno_VS_Jupiterlab/Datasets/valentines_day_spending_dataset.csv')
# Saltaba error de definición para df_esp en esta celda incluyo esta llamada al cambio de nombres
df_esp = df.rename(columns=columns_esp)
df_esp_alter = df_esp

# Ahora voy a eliminar las columnas que no tengan valor en tipo_de_regalo
# Por coherencia hago los cambios en una variable alternativa
# Dropna sin el argumento subset elimina todas las columnas con valores nulos
# Se puede aplicar sobre una o varias columnas no olvidarse de los corchetes en tal caso
df_esp_alter.dropna(subset= ['tipo_de_regalo'], inplace = True)
print(df_esp_alter.isna().sum())








